class Solution {
public:
    vector<int> constructList(vector<vector<int>> &queries) {
        vector<int> ans = {0};
        int xr = 0;

        for (auto &q : queries) {
            int type = q[0];
            int x = q[1];

            if (type == 0)
                ans.push_back(x ^ xr);
            else
                xr ^= x;
        }

        for (int &x : ans)
            x ^= xr;

        sort(ans.begin(), ans.end());
        return ans;
    }
};



/*Initialize
Create a list ans = [0]
Set xr = 0 (this stores global XOR effect)
Process each query
If query is [0, x]:

Insert adjusted value:

ans.push_back(x XOR xr)
If query is [1, x]:

Update global XOR:

xr = xr XOR x
Finalize the list

For each element in ans:

element = element XOR xr
Sort and return
Sort ans in increasing order
Return ans*/

class Solution {
public:
    bool kSubstr(string &s, int k) {
        int n = s.size();

        if (n % k != 0) return false;

        unordered_map<string, int> freq;

        int blocks = n / k;
        int mx = 0;

        for (int i = 0; i < n; i += k) {
            string cur = s.substr(i, k);
            mx = max(mx, ++freq[cur]);
        }

        return (blocks - mx <= 1);
    }
};

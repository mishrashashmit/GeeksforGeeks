/* Structure of a Linked List node
class Node {
  public:
    int data;
    Node* next;

    Node(int x) {
        data = x;
        next = nullptr;
    }
};
*/
class Solution {
public:
    Node* reverseList(Node* head) {
        Node* prev = NULL;
        Node* curr = head;

        while (curr) {
            Node* next = curr->next;
            curr->next = prev;
            prev = curr;
            curr = next;
        }

        return prev;
    }

    Node *compute(Node *head) {
        if (!head || !head->next)
            return head;

        head = reverseList(head);

        Node* curr = head;
        int maxi = curr->data;

        while (curr && curr->next) {
            if (curr->next->data < maxi) {
                curr->next = curr->next->next;
            } else {
                curr = curr->next;
                maxi = curr->data;
            }
        }

        return reverseList(head);
    }
};
